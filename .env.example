# ═══════════════════════════════════════════════════════════════
# Daly BMS Interface — Fichier de configuration exemple
# Copier ce fichier en .env et adapter les valeurs
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────
# UART / RS485
# ───────────────────────────────────────────
DALY_PORT=/dev/ttyUSB0          # Port série (ex: /dev/ttyUSB0, /dev/ttyAMA0)
DALY_BAUDRATE=9600              # Vitesse UART (défaut Daly : 9600)
DALY_TIMEOUT=1.0                # Timeout réponse BMS en secondes
DALY_POLL_INTERVAL=1.0          # Intervalle de lecture en secondes
DALY_CELL_COUNT=16              # Nombre de cellules par BMS
DALY_SENSOR_COUNT=4             # Nombre de sondes NTC par BMS

# ───────────────────────────────────────────
# API FastAPI
# ───────────────────────────────────────────
DALY_API_KEY=changeme           # Clé d'authentification API (laisser vide pour désactiver)
DALY_API_HOST=0.0.0.0           # Interface d'écoute
DALY_API_PORT=8000              # Port HTTP
DALY_RING_SIZE=3600             # Taille du buffer circulaire (points d'historique)

# ───────────────────────────────────────────
# MQTT — Broker local (RPi CM5 / Mosquitto)
# ───────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=                      # Laisser vide si pas d'auth
MQTT_PASSWORD=
MQTT_CLIENT_ID=dalybms-rpi
MQTT_TOPIC_PREFIX=santuario/bms
MQTT_PUBLISH_INTERVAL=5         # Intervalle de publication en secondes
MQTT_BMS1_NAME=pack-320ah
MQTT_BMS2_NAME=pack-360ah

# ───────────────────────────────────────────
# MQTT Bridge — NanoPi / Venus OS
# ───────────────────────────────────────────
NANOPI_MQTT_HOST=192.168.1.xx   # IP du NanoPi (à adapter)
NANOPI_MQTT_PORT=1883
NANOPI_MQTT_USER=
NANOPI_MQTT_PASSWORD=
VENUS_PORTAL_ID=c0619ab9929a    # Portal ID Victron (visible dans Venus OS)
VENUS_BMS1_INSTANCE=1           # Instance dbus batterie 1
VENUS_BMS2_INSTANCE=2           # Instance dbus batterie 2
VENUS_BMS1_CAPACITY=320         # Capacité en Ah
VENUS_BMS2_CAPACITY=360
VENUS_PUBLISH_INTERVAL=10       # Intervalle Venus en secondes
VENUS_KEEPALIVE_INTERVAL=55     # Keepalive Venus OS (ne pas descendre sous 60s)

# ───────────────────────────────────────────
# InfluxDB 2.x
# ───────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=changeme           # Token généré lors de l'init InfluxDB
INFLUX_ORG=santuario
INFLUX_BUCKET=dalybms
INFLUX_BUCKET_DS=dalybms_1m     # Bucket downsampled (1 minute)
INFLUX_RETENTION_RAW=720h       # Rétention données brutes (30 jours)
INFLUX_RETENTION_DS=8760h       # Rétention données agrégées (365 jours)
INFLUX_BATCH_SIZE=50            # Nombre de points avant flush
INFLUX_FLUSH_INTERVAL=5         # Flush forcé toutes les N secondes

# ───────────────────────────────────────────
# Alertes — Telegram
# ───────────────────────────────────────────
TELEGRAM_BOT_TOKEN=             # Token BotFather (laisser vide pour désactiver)
TELEGRAM_CHAT_ID=               # ID du chat ou groupe

# ───────────────────────────────────────────
# Alertes — Email SMTP
# ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                      # Adresse email expéditeur
SMTP_PASSWORD=                  # Mot de passe ou App Password
SMTP_RECIPIENT=                 # Adresse email destinataire
SMTP_ENABLED=false              # true pour activer

# ───────────────────────────────────────────
# Seuils d'alerte (valeurs par défaut LiFePO4 16S)
# ───────────────────────────────────────────
ALERT_CELL_OV=3.65              # Surtension cellule (V)
ALERT_CELL_UV=2.80              # Sous-tension cellule (V)
ALERT_CELL_DELTA=0.100          # Déséquilibre max entre cellules (V)
ALERT_SOC_WARN=20               # SOC avertissement (%)
ALERT_SOC_CRIT=10               # SOC critique (%)
ALERT_TEMP_MAX=45               # Température max (°C)
ALERT_CURRENT_MAX=100           # Courant max (A)
