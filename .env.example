# ═══════════════════════════════════════════════════════════════
# Daly BMS Interface — Fichier de configuration exemple
# Copier ce fichier en .env et adapter les valeurs
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────
# UART / RS485  (daly_protocol.py, daly_api.py)
# ───────────────────────────────────────────
DALY_PORT=/dev/ttyUSB0          # Port série (ex: /dev/ttyUSB0, /dev/ttyAMA0)
DALY_BAUDRATE=9600              # Vitesse UART (défaut Daly : 9600)
DALY_TIMEOUT=1.0                # Timeout réponse BMS en secondes
DALY_POLL_INTERVAL=1.0          # Intervalle de lecture en secondes
DALY_CELL_COUNT=16              # Nombre de cellules par BMS
DALY_SENSOR_COUNT=4             # Nombre de sondes NTC par BMS

# ───────────────────────────────────────────
# API FastAPI  (daly_api.py)
# ───────────────────────────────────────────
DALY_API_KEY=changeme           # Clé d'authentification API (laisser vide pour désactiver)
DALY_RING_SIZE=3600             # Taille du buffer circulaire (points d'historique)

# ───────────────────────────────────────────
# MQTT — Broker local  (daly_mqtt.py)
# ───────────────────────────────────────────
MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USER=                      # Laisser vide si pas d'auth
MQTT_PASS=                      # Mot de passe MQTT (var: MQTT_PASS)
MQTT_CLIENT_ID=daly-bms-service
MQTT_PREFIX=santuario/bms       # Préfixe de tous les topics (var: MQTT_PREFIX)
MQTT_INTERVAL=5.0               # Intervalle de publication en secondes (var: MQTT_INTERVAL)
MQTT_QOS_DATA=0                 # QoS pour métriques continues
MQTT_QOS_ALARM=1                # QoS pour alarmes critiques
MQTT_QOS_STATUS=1               # QoS pour état MOS
MQTT_BMS1_NAME=pack_320ah       # Nom BMS 1 dans les topics
MQTT_BMS2_NAME=pack_360ah       # Nom BMS 2 dans les topics

# ───────────────────────────────────────────
# MQTT Bridge — Republication vers NanoPi  (daly_mqtt.py)
# ───────────────────────────────────────────
MQTT_BRIDGE_ENABLED=false        # true pour activer le bridge vers NanoPi
MQTT_BRIDGE_HOST=192.168.1.120   # IP du NanoPi
MQTT_BRIDGE_PORT=1883
MQTT_BRIDGE_PREFIX=santuario/bms # Préfixe topics sur le broker NanoPi

# ───────────────────────────────────────────
# MQTT Bridge — Venus OS / NanoPi  (daly_venus.py)
# ───────────────────────────────────────────
NANOPI_MQTT_HOST=192.168.1.120   # IP du NanoPi (à adapter)
NANOPI_MQTT_PORT=1883
NANOPI_MQTT_USER=
NANOPI_MQTT_PASS=                # Mot de passe NanoPi MQTT (var: NANOPI_MQTT_PASS)
NANOPI_CLIENT_ID=dalybms-venus-bridge
LOCAL_MQTT_HOST=localhost         # Broker MQTT local pour reception des snapshots
LOCAL_MQTT_PORT=1883

VENUS_PORTAL_ID=c0619ab9929a     # Portal ID Victron (visible dans Venus OS)
VENUS_BMS1_INSTANCE=10           # Instance dbus batterie 1
VENUS_BMS2_INSTANCE=11           # Instance dbus batterie 2
VENUS_METEO_INSTANCE=20          # Instance dbus meteo
VENUS_PUBLISH_INTERVAL=5.0       # Intervalle Venus en secondes
VENUS_KEEPALIVE_INTERVAL=55.0    # Keepalive Venus OS (ne pas descendre sous 60s)

BMS1_PRODUCT_NAME=Daly LiFePO4 320Ah
BMS2_PRODUCT_NAME=Daly LiFePO4 360Ah
BMS1_CAPACITY_AH=320             # Capacité pack 1 en Ah
BMS2_CAPACITY_AH=360             # Capacité pack 2 en Ah

# ───────────────────────────────────────────
# InfluxDB 2.x  (daly_influx.py)
# ───────────────────────────────────────────
INFLUX_URL=http://localhost:8086
INFLUX_TOKEN=changeme            # Token généré lors de l'init InfluxDB
INFLUX_ORG=santuario
INFLUX_BUCKET=daly_bms           # Bucket données brutes (var: INFLUX_BUCKET)
INFLUX_BUCKET_DS=daly_bms_1m    # Bucket downsampled — 1 minute (var: INFLUX_BUCKET_DS)
INFLUX_BATCH_SIZE=50             # Nombre de points avant flush (var: INFLUX_BATCH_SIZE)
INFLUX_BATCH_INTERVAL=5.0        # Flush forcé toutes les N secondes (var: INFLUX_BATCH_INTERVAL)
INFLUX_RETENTION_DAYS=30         # Rétention données brutes en jours (var: INFLUX_RETENTION_DAYS)
INFLUX_WRITE_INTERVAL=1.0        # Intervalle écriture points en secondes (var: INFLUX_WRITE_INTERVAL)
INFLUX_BMS1_NAME=pack_320ah      # Nom tag BMS 1
INFLUX_BMS2_NAME=pack_360ah      # Nom tag BMS 2
INFLUX_INSTALLATION=santuario    # Tag installation (var: INFLUX_INSTALLATION)

# ───────────────────────────────────────────
# Alertes — Telegram  (daly_alerts.py)
# ───────────────────────────────────────────
TELEGRAM_TOKEN=                  # Token BotFather (laisser vide pour désactiver) (var: TELEGRAM_TOKEN)
TELEGRAM_CHAT_ID=                # ID du chat ou groupe

# ───────────────────────────────────────────
# Alertes — Email SMTP  (daly_alerts.py)
# ───────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                       # Adresse email expéditeur (compte SMTP)
SMTP_PASS=                       # Mot de passe ou App Password (var: SMTP_PASS)
SMTP_FROM=daly-bms@santuario.local  # Adresse expéditeur affiché (var: SMTP_FROM)
SMTP_TO=                         # Adresse email destinataire (var: SMTP_TO)

# ───────────────────────────────────────────
# Alertes — Nommage et base de données  (daly_alerts.py)
# ───────────────────────────────────────────
ALERT_DB_PATH=/data/dalybms/alerts.db  # Chemin base SQLite des alertes
ALERT_CHECK_INTERVAL=1.0         # Intervalle de vérification des alertes en secondes
ALERT_BMS1_NAME=Pack 320Ah       # Nom BMS 1 dans les messages d'alerte
ALERT_BMS2_NAME=Pack 360Ah       # Nom BMS 2 dans les messages d'alerte
