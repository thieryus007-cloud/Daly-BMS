# ─────────────────────────────────────────────────────────────────────────────
# DalyBMS — Variables d'environnement Docker (infrastructure)
#
# Copier ce fichier :  cp .env.docker.example .env.docker
# Puis éditer les valeurs ci-dessous avant de faire : make up
#
# NOTE : ce fichier est distinct du .env utilisé par les scripts Python.
#        Les deux peuvent coexister sans conflit.
# ─────────────────────────────────────────────────────────────────────────────

# ── InfluxDB ──────────────────────────────────────────────────────────────────
INFLUX_ADMIN_USER=admin
INFLUX_ADMIN_PASSWORD=changeme123        # min 8 caractères
INFLUX_ORG=santuario
INFLUX_BUCKET=daly_bms
INFLUX_TOKEN=mon-token-super-secret      # copier aussi dans le .env Python

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme

# ── Rétention des données InfluxDB ───────────────────────────────────────────
INFLUX_RETENTION_DAYS=30
